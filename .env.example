NODE_ENV=development

# Database (Neon/PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/totem

# API
API_PORT=4000
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3003,http://127.0.0.1:3003
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=7d
ENABLE_SWAGGER=true
MESSAGING_CAMPAIGNS_ENABLED=false

# App URLs
FRONTEND_URL=http://localhost:3003
NEXT_PUBLIC_APP_URL=http://localhost:3003
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_STYLE=mapbox/light-v11
MAPBOX_TOKEN=

# Email SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Totem <noreply@totem-ecole.fr>"

# Twilio SMS (production)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_STATUS_CALLBACK_URL=https://api.your-domain.com/api/messages/webhooks/twilio/status
