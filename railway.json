{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run db:generate --workspace @totem/database && npm run build --workspace @totem/api"
  },
  "deploy": {
    "startCommand": "npm run start --workspace @totem/api",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 180
  }
}
